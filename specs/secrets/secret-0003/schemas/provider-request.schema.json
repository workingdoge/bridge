{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/secret-0003/provider-request.schema.json",
  "title": "ProviderRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "trace",
    "deployment_profile_id",
    "subject_id",
    "consumer_id",
    "consumer_kind",
    "secret_ref",
    "secret_class",
    "requested_capability",
    "requested_method",
    "requested_ttl_s",
    "required_posture_digest"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "trace": {
      "type": "string"
    },
    "deployment_profile_id": {
      "type": "string"
    },
    "subject_id": {
      "type": "string"
    },
    "consumer_id": {
      "type": "string"
    },
    "consumer_kind": {
      "type": "string",
      "enum": [
        "systemd-unit",
        "process",
        "launchd-service",
        "kubernetes-pod",
        "sidecar",
        "ci-job"
      ]
    },
    "secret_ref": {
      "type": "string"
    },
    "secret_class": {
      "type": "string"
    },
    "requested_capability": {
      "type": "string",
      "enum": [
        "materialize",
        "issue-dynamic",
        "decrypt",
        "sign",
        "proxy-operation"
      ]
    },
    "requested_method": {
      "type": "string",
      "enum": [
        "systemd-credential",
        "memfd-pass",
        "unix-socket-proxy",
        "tmpfs-file",
        "cloud-kms-decrypt",
        "os-keychain-ref",
        "agent-proxy"
      ]
    },
    "requested_ttl_s": {
      "type": "integer",
      "minimum": 1
    },
    "required_posture_digest": {
      "type": "string"
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  }
}

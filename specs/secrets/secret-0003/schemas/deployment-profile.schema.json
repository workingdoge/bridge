{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/secret-0003/deployment-profile.schema.json",
  "title": "DeploymentProfile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "deployment_profile_id",
    "environment_type",
    "platform",
    "providers",
    "secret_class_bindings",
    "logging_policy",
    "burn_policy"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "deployment_profile_id": {
      "type": "string",
      "minLength": 1
    },
    "environment_type": {
      "type": "string",
      "enum": [
        "workstation-local",
        "nixos-service-host",
        "cloud-agent-worker",
        "ci-runner"
      ]
    },
    "platform": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "os_family"
      ],
      "properties": {
        "os_family": {
          "type": "string",
          "enum": [
            "linux",
            "darwin",
            "container",
            "mixed"
          ]
        },
        "orchestrator": {
          "type": "string",
          "enum": [
            "systemd",
            "launchd",
            "kubernetes",
            "none"
          ]
        },
        "identity_mode": {
          "type": "string",
          "enum": [
            "user",
            "workload",
            "hybrid"
          ]
        }
      }
    },
    "providers": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "time_authority",
        "revocation",
        "attestation",
        "mode_controller",
        "audit_sink"
      ],
      "properties": {
        "time_authority": {
          "type": "string"
        },
        "revocation": {
          "type": "string"
        },
        "attestation": {
          "type": "string"
        },
        "mode_controller": {
          "type": "string"
        },
        "audit_sink": {
          "type": "string"
        },
        "secret_backends": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "materializers": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "emergency_queue": {
          "type": "string"
        }
      }
    },
    "secret_class_bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "secret_class",
          "backend_provider_id",
          "materializer_provider_id",
          "max_ttl_s",
          "allowed_consumer_kinds"
        ],
        "properties": {
          "secret_class": {
            "type": "string"
          },
          "backend_provider_id": {
            "type": "string"
          },
          "materializer_provider_id": {
            "type": "string"
          },
          "max_ttl_s": {
            "type": "integer",
            "minimum": 1
          },
          "allowed_consumer_kinds": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "systemd-unit",
                "process",
                "launchd-service",
                "kubernetes-pod",
                "sidecar",
                "ci-job"
              ]
            },
            "uniqueItems": true
          },
          "requires_attestation": {
            "type": "boolean",
            "default": true
          },
          "allow_exportable": {
            "type": "boolean",
            "default": false
          }
        }
      }
    },
    "logging_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "transcript_allowed",
        "redact_fields"
      ],
      "properties": {
        "transcript_allowed": {
          "type": "boolean"
        },
        "redact_fields": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "burn_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allow_emergency_queue",
        "propagation_window_s",
        "restore_requires_fresh_attestation",
        "restore_requires_new_epoch"
      ],
      "properties": {
        "allow_emergency_queue": {
          "type": "boolean"
        },
        "propagation_window_s": {
          "type": "integer",
          "minimum": 0
        },
        "restore_requires_fresh_attestation": {
          "type": "boolean"
        },
        "restore_requires_new_epoch": {
          "type": "boolean"
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/secret-0003/provider-catalog.schema.json",
  "title": "ProviderCatalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "catalog_id",
    "providers"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "catalog_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "providers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "provider_id",
          "kind",
          "trust_boundary",
          "capabilities",
          "fail_closed",
          "max_fact_age_s",
          "allowed_modes"
        ],
        "properties": {
          "provider_id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "time-authority",
              "revocation",
              "attestation",
              "mode-controller",
              "audit-sink",
              "secret-backend",
              "materializer"
            ]
          },
          "product_family": {
            "type": "string",
            "enum": [
              "generic",
              "vault",
              "aws-kms",
              "gcp-kms",
              "azure-key-vault",
              "pkcs11-hsm",
              "apple-keychain",
              "spire",
              "oidc",
              "tpm-attestation",
              "systemd-credential",
              "unix-socket-proxy",
              "tmpfs-file",
              "memfd-pass",
              "agent-proxy",
              "file-sealed-queue",
              "append-only-log"
            ]
          },
          "endpoint_ref": {
            "type": "string"
          },
          "trust_boundary": {
            "type": "string",
            "minLength": 1
          },
          "capabilities": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "fail_closed": {
            "type": "boolean"
          },
          "max_fact_age_s": {
            "type": "integer",
            "minimum": 1
          },
          "allowed_modes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "normal",
                "degraded",
                "safe",
                "burn"
              ]
            },
            "uniqueItems": true
          },
          "requires_attestation": {
            "type": "boolean",
            "default": false
          },
          "requires_durable_audit": {
            "type": "boolean",
            "default": true
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}

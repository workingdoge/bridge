{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/secret-0003/audit-checkpoint.schema.json",
  "title": "AuditCheckpoint",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "stream_id",
    "last_sequence",
    "last_event_hash",
    "checkpointed_at",
    "sink_id"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "stream_id": {
      "type": "string"
    },
    "last_sequence": {
      "type": "integer",
      "minimum": 0
    },
    "last_event_hash": {
      "type": "string"
    },
    "checkpointed_at": {
      "type": "string",
      "format": "date-time"
    },
    "sink_id": {
      "type": "string"
    }
  }
}

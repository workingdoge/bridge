{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/secret-0003/mode-state.schema.json",
  "title": "ModeState",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "mode",
    "mode_epoch",
    "changed_at",
    "controller_id"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": [
        "normal",
        "degraded",
        "safe",
        "burn"
      ]
    },
    "mode_epoch": {
      "type": "integer",
      "minimum": 0
    },
    "changed_at": {
      "type": "string",
      "format": "date-time"
    },
    "controller_id": {
      "type": "string"
    },
    "scope": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "restore_prereqs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  }
}

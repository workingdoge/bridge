{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/secret-0003/attestation-result.schema.json",
  "title": "AttestationResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "attestation_id",
    "subject_id",
    "subject_kind",
    "verifier_id",
    "posture_digest",
    "status",
    "measured_at",
    "expires_at"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "attestation_id": {
      "type": "string"
    },
    "subject_id": {
      "type": "string"
    },
    "subject_kind": {
      "type": "string",
      "enum": [
        "host",
        "workload",
        "device",
        "user-session"
      ]
    },
    "verifier_id": {
      "type": "string"
    },
    "posture_digest": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "verified",
        "degraded",
        "failed"
      ]
    },
    "measured_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "claims": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean",
          "array",
          "object",
          "null"
        ]
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  }
}

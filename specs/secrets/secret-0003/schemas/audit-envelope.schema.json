{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/secret-0003/audit-envelope.schema.json",
  "title": "AuditEnvelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "stream_id",
    "sequence",
    "prev_event_hash",
    "event_hash",
    "emitted_at",
    "source_id",
    "trace",
    "event_type",
    "payload_hash"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "stream_id": {
      "type": "string"
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "prev_event_hash": {
      "type": "string"
    },
    "event_hash": {
      "type": "string"
    },
    "emitted_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_id": {
      "type": "string"
    },
    "trace": {
      "type": "string"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "decision.allow",
        "decision.deny",
        "decision.burn",
        "materialize.start",
        "materialize.stop",
        "secret.rotate",
        "secret.revoke",
        "secret.destroy",
        "mode.burn",
        "mode.restore"
      ]
    },
    "payload_hash": {
      "type": "string"
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "decision_status": {
      "type": "string",
      "enum": [
        "accept",
        "deny",
        "burn"
      ]
    },
    "notes": {
      "type": "string"
    }
  }
}

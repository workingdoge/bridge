{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/secret-0003/revocation-snapshot.schema.json",
  "title": "RevocationSnapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "snapshot_id",
    "observed_at",
    "fresh_until",
    "issuer_epoch",
    "revoked_issuers",
    "revoked_jtis",
    "revoked_secret_epochs"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "snapshot_id": {
      "type": "string"
    },
    "source_id": {
      "type": "string"
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "fresh_until": {
      "type": "string",
      "format": "date-time"
    },
    "issuer_epoch": {
      "type": "integer",
      "minimum": 0
    },
    "revoked_issuers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "revoked_jtis": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "revoked_secret_epochs": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 0
      },
      "uniqueItems": true
    },
    "revoked_secret_versions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/secret-0003/provider-decision.schema.json",
  "title": "ProviderDecision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "trace",
    "status",
    "deployment_profile_id",
    "mode",
    "audit_required",
    "reasons"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "trace": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "accept",
        "deny",
        "burn"
      ]
    },
    "deployment_profile_id": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": [
        "normal",
        "degraded",
        "safe",
        "burn"
      ]
    },
    "selected_backend_provider_id": {
      "type": "string"
    },
    "selected_materializer_provider_id": {
      "type": "string"
    },
    "attestation_id": {
      "type": "string"
    },
    "revocation_snapshot_id": {
      "type": "string"
    },
    "audit_required": {
      "type": "boolean"
    },
    "audit_sink_id": {
      "type": "string"
    },
    "session_expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "provider_facts": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean",
          "array",
          "object",
          "null"
        ]
      }
    }
  }
}

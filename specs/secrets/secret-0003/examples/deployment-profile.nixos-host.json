{
  "version": "0.1",
  "deployment_profile_id": "nixos-host-main",
  "environment_type": "nixos-service-host",
  "platform": {
    "os_family": "linux",
    "orchestrator": "systemd",
    "identity_mode": "workload"
  },
  "providers": {
    "time_authority": "time-main",
    "revocation": "revoke-main",
    "attestation": "attest-main",
    "mode_controller": "mode-main",
    "audit_sink": "audit-main",
    "secret_backends": [
      "vault-dynamic-main",
      "kms-envelope-main",
      "hsm-proxy-main"
    ],
    "materializers": [
      "systemd-cred-main",
      "unix-socket-proxy-main",
      "memfd-pass-main"
    ],
    "emergency_queue": "audit-emergency-queue"
  },
  "secret_class_bindings": [
    {
      "secret_class": "database-credential",
      "backend_provider_id": "vault-dynamic-main",
      "materializer_provider_id": "systemd-cred-main",
      "max_ttl_s": 600,
      "allowed_consumer_kinds": [
        "systemd-unit"
      ],
      "requires_attestation": true,
      "allow_exportable": false
    },
    {
      "secret_class": "signing-key",
      "backend_provider_id": "hsm-proxy-main",
      "materializer_provider_id": "unix-socket-proxy-main",
      "max_ttl_s": 300,
      "allowed_consumer_kinds": [
        "systemd-unit",
        "sidecar"
      ],
      "requires_attestation": true,
      "allow_exportable": false
    }
  ],
  "logging_policy": {
    "transcript_allowed": false,
    "redact_fields": [
      "secret",
      "plaintext",
      "token",
      "credential",
      "key"
    ]
  },
  "burn_policy": {
    "allow_emergency_queue": true,
    "propagation_window_s": 30,
    "restore_requires_fresh_attestation": true,
    "restore_requires_new_epoch": true
  },
  "notes": "Example NixOS host profile."
}

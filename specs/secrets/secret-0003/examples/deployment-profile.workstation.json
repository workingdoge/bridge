{
  "version": "0.1",
  "deployment_profile_id": "workstation-main",
  "environment_type": "workstation-local",
  "platform": {
    "os_family": "darwin",
    "orchestrator": "launchd",
    "identity_mode": "hybrid"
  },
  "providers": {
    "time_authority": "time-main",
    "revocation": "revoke-main",
    "attestation": "attest-main",
    "mode_controller": "mode-main",
    "audit_sink": "audit-main",
    "secret_backends": [
      "keychain-local",
      "vault-dynamic-main"
    ],
    "materializers": [
      "agent-proxy-main",
      "memfd-pass-main"
    ],
    "emergency_queue": "audit-emergency-queue"
  },
  "secret_class_bindings": [
    {
      "secret_class": "bootstrap-secret",
      "backend_provider_id": "keychain-local",
      "materializer_provider_id": "agent-proxy-main",
      "max_ttl_s": 300,
      "allowed_consumer_kinds": [
        "process",
        "launchd-service"
      ],
      "requires_attestation": false,
      "allow_exportable": false
    },
    {
      "secret_class": "database-credential",
      "backend_provider_id": "vault-dynamic-main",
      "materializer_provider_id": "agent-proxy-main",
      "max_ttl_s": 300,
      "allowed_consumer_kinds": [
        "process",
        "launchd-service"
      ],
      "requires_attestation": true,
      "allow_exportable": false
    }
  ],
  "logging_policy": {
    "transcript_allowed": false,
    "redact_fields": [
      "secret",
      "plaintext",
      "token",
      "credential",
      "key"
    ]
  },
  "burn_policy": {
    "allow_emergency_queue": true,
    "propagation_window_s": 30,
    "restore_requires_fresh_attestation": true,
    "restore_requires_new_epoch": true
  },
  "notes": "Example local workstation profile."
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/secret-0002/signature-response.schema.json",
  "title": "SECRET-0002 Signature Response",
  "description": "Typed result of a signer-session request over a local broker transport.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_id",
    "session_id",
    "decision"
  ],
  "properties": {
    "schema_version": {
      "const": "secret-0002-signature-0.1"
    },
    "request_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "session_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "bridge_trace": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "decision": {
      "type": "string",
      "enum": [
        "allow",
        "deny"
      ]
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format",
        "value"
      ],
      "properties": {
        "format": {
          "type": "string",
          "enum": [
            "hex-65",
            "rsv-hex",
            "opaque-ref"
          ]
        },
        "value": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        }
      }
    },
    "signer_identity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "address": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{40}$"
        },
        "key_ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        }
      }
    },
    "deny_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 256
      },
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "decision": {
            "const": "allow"
          }
        }
      },
      "then": {
        "required": [
          "signature"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "decision": {
            "const": "deny"
          }
        }
      },
      "then": {
        "required": [
          "deny_reasons"
        ]
      }
    }
  ]
}

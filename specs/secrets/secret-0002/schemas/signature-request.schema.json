{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/secret-0002/signature-request.schema.json",
  "title": "SECRET-0002 Signature Request",
  "description": "Typed request carried over a local signer-session transport after a signing-key materialization session is issued.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_id",
    "session_id",
    "operation",
    "payload"
  ],
  "properties": {
    "schema_version": {
      "const": "secret-0002-signature-0.1"
    },
    "request_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "session_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "bridge_trace": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "consumer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "service",
            "systemd-unit",
            "pid",
            "k8s-pod",
            "ci-job",
            "dev-shell",
            "macos-process"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        }
      }
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "algorithm"
      ],
      "properties": {
        "kind": {
          "const": "sign"
        },
        "algorithm": {
          "type": "string",
          "enum": [
            "secp256k1-raw32",
            "secp256k1-eth-transaction",
            "secp256k1-eip191",
            "secp256k1-eip712"
          ]
        },
        "encoding": {
          "type": "string",
          "enum": [
            "hex-65",
            "rsv-hex",
            "ieee-p1363"
          ]
        }
      }
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "digest32",
            "typed-data-hash",
            "transaction-envelope-ref",
            "opaque-payload-ref"
          ]
        },
        "digest": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{64}$"
        },
        "payload_ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        },
        "chain_id": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2147483647
        },
        "purpose": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "enum": [
                  "digest32",
                  "typed-data-hash"
                ]
              }
            }
          },
          "then": {
            "required": [
              "digest"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "enum": [
                  "transaction-envelope-ref",
                  "opaque-payload-ref"
                ]
              }
            }
          },
          "then": {
            "required": [
              "payload_ref"
            ]
          }
        }
      ]
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "content_ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        },
        "nonce": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        }
      }
    }
  }
}

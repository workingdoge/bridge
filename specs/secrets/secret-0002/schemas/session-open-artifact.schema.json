{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/secret-0002/session-open-artifact.schema.json",
  "title": "SECRET-0002 Session Open Artifact",
  "description": "Typed composite open-session artifact derived from an issued signing-key materialization session when a downstream protocol needs explicit settlement material beyond a bare signer handle.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_id",
    "session_id",
    "bridge_trace",
    "action",
    "decision"
  ],
  "properties": {
    "schema_version": {
      "const": "secret-0002-session-open-0.1"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "session_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "bridge_trace": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "action": {
      "const": "open"
    },
    "credential_family": {
      "type": "string",
      "enum": [
        "tempo-session"
      ]
    },
    "decision": {
      "type": "string",
      "enum": [
        "allow",
        "deny"
      ]
    },
    "transaction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "encoding",
        "value"
      ],
      "properties": {
        "encoding": {
          "type": "string",
          "enum": [
            "0x-prefixed-hex",
            "base64",
            "opaque-ref"
          ]
        },
        "value": {
          "type": "string",
          "minLength": 1,
          "maxLength": 16384
        }
      }
    },
    "channel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "channel_id",
        "derivation"
      ],
      "properties": {
        "channel_id": {
          "type": "string",
          "minLength": 8,
          "maxLength": 256
        },
        "derivation": {
          "type": "string",
          "enum": [
            "transaction-bound",
            "provider-defined",
            "application-deterministic"
          ]
        }
      }
    },
    "voucher": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cumulative_amount",
        "signature"
      ],
      "properties": {
        "cumulative_amount": {
          "type": "string",
          "pattern": "^(0|[1-9][0-9]{0,38})$"
        },
        "signature": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "format",
            "value"
          ],
          "properties": {
            "format": {
              "type": "string",
              "enum": [
                "hex-65",
                "rsv-hex",
                "opaque-ref"
              ]
            },
            "value": {
              "type": "string",
              "minLength": 1,
              "maxLength": 4096
            }
          }
        }
      }
    },
    "signer_identity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "address": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{40}$"
        },
        "key_ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        }
      }
    },
    "deny_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 256
      },
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "decision": {
            "const": "allow"
          }
        }
      },
      "then": {
        "required": [
          "credential_family",
          "transaction",
          "channel",
          "voucher"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "decision": {
            "const": "deny"
          }
        }
      },
      "then": {
        "required": [
          "deny_reasons"
        ]
      }
    }
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/secret-0002/witness-realization-record.schema.json",
  "title": "SECRET-0002 Witness Realization Record",
  "description": "Bridge-local coherence record over materialization sessions, signer operations, audit evidence, and validation results.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "realization_id",
    "bridge_trace",
    "challenge",
    "state_read",
    "action_selection",
    "witness_plan",
    "witness_artifact",
    "validator_profile",
    "validation_result",
    "state_transition"
  ],
  "properties": {
    "schema_version": {
      "const": "secret-0002-witness-realization-0.1"
    },
    "realization_id": {
      "$ref": "#/$defs/tokenId"
    },
    "bridge_trace": {
      "$ref": "#/$defs/tokenId"
    },
    "challenge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "challenge_id",
        "challenge_kind",
        "domain",
        "requested_action"
      ],
      "properties": {
        "challenge_id": {
          "$ref": "#/$defs/tokenId"
        },
        "challenge_kind": {
          "type": "string",
          "enum": [
            "session-issuance",
            "signer-operation",
            "session-teardown",
            "mode-change",
            "foreign-validation"
          ]
        },
        "domain": {
          "type": "string",
          "enum": [
            "materialization",
            "signing-key",
            "audit",
            "compatibility"
          ]
        },
        "requested_action": {
          "$ref": "#/$defs/actionRef"
        }
      }
    },
    "state_read": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "materialization_session_ref",
        "session_state",
        "bridge_decision_effect"
      ],
      "properties": {
        "materialization_session_ref": {
          "$ref": "#/$defs/tokenId"
        },
        "signature_request_ref": {
          "$ref": "#/$defs/tokenId"
        },
        "signature_response_ref": {
          "$ref": "#/$defs/tokenId"
        },
        "audit_ref": {
          "$ref": "#/$defs/refString"
        },
        "compatibility_witness_ref": {
          "$ref": "#/$defs/refString"
        },
        "session_state": {
          "$ref": "#/$defs/sessionState"
        },
        "bridge_decision_effect": {
          "type": "string",
          "enum": [
            "accept",
            "deny",
            "burn"
          ]
        },
        "authority_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/refString"
          },
          "uniqueItems": true
        }
      }
    },
    "action_selection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selected_action",
        "basis"
      ],
      "properties": {
        "selected_action": {
          "$ref": "#/$defs/actionKind"
        },
        "basis": {
          "type": "string",
          "enum": [
            "bridge-decision",
            "session-state",
            "consumer-match",
            "epoch-check",
            "attestation-check",
            "burn-state",
            "validator-result"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        }
      }
    },
    "witness_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plan_id",
        "artifact_kind",
        "validator_profile_id"
      ],
      "properties": {
        "plan_id": {
          "$ref": "#/$defs/tokenId"
        },
        "artifact_kind": {
          "$ref": "#/$defs/artifactKind"
        },
        "validator_profile_id": {
          "$ref": "#/$defs/refString"
        }
      }
    },
    "witness_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_kind",
        "artifact_ref",
        "artifact_digest"
      ],
      "properties": {
        "artifact_kind": {
          "$ref": "#/$defs/artifactKind"
        },
        "artifact_ref": {
          "$ref": "#/$defs/refString"
        },
        "artifact_digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "validator_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_id",
        "profile_kind"
      ],
      "properties": {
        "profile_id": {
          "$ref": "#/$defs/refString"
        },
        "profile_kind": {
          "type": "string",
          "enum": [
            "bridge-adapter",
            "secret-materializer",
            "signer-broker",
            "provider-sidecar",
            "premath-gluing"
          ]
        },
        "law_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/refString"
          },
          "uniqueItems": true
        }
      }
    },
    "validation_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result_id",
        "verdict"
      ],
      "properties": {
        "result_id": {
          "$ref": "#/$defs/tokenId"
        },
        "verdict": {
          "type": "string",
          "enum": [
            "accepted",
            "denied",
            "burned",
            "stale",
            "ambiguous"
          ]
        },
        "deny_reasons": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/refString"
          },
          "uniqueItems": true
        }
      }
    },
    "state_transition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "transition_id",
        "from_state",
        "to_state"
      ],
      "properties": {
        "transition_id": {
          "$ref": "#/$defs/tokenId"
        },
        "from_state": {
          "$ref": "#/$defs/sessionState"
        },
        "to_state": {
          "$ref": "#/$defs/sessionState"
        },
        "receipt_ref": {
          "$ref": "#/$defs/refString"
        },
        "next_session_epoch": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2147483647
        }
      }
    }
  },
  "$defs": {
    "tokenId": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "refString": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "actionKind": {
      "type": "string",
      "enum": [
        "issue-session",
        "deny-session",
        "sign",
        "refuse-signature",
        "revoke-session",
        "expire-session",
        "tear-down-session",
        "burn-session"
      ]
    },
    "actionRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "$ref": "#/$defs/actionKind"
        },
        "ref": {
          "$ref": "#/$defs/refString"
        }
      }
    },
    "artifactKind": {
      "type": "string",
      "enum": [
        "materialization-session",
        "signature-request",
        "signature-response",
        "audit-record",
        "audit-envelope",
        "compatibility-witness",
        "denial-reason"
      ]
    },
    "sessionState": {
      "type": "string",
      "enum": [
        "planned",
        "issued",
        "revoked",
        "expired",
        "denied",
        "torn_down"
      ]
    },
    "digest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "alg",
        "value"
      ],
      "properties": {
        "alg": {
          "const": "sha256"
        },
        "value": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/secret-0002/materialization-plan-request.schema.json",
  "title": "SECRET-0002 Materialization Plan Request",
  "description": "Bridge-authorized handoff from admission into secret materialization planning.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_id",
    "bridge",
    "resource_binding",
    "secret",
    "consumer",
    "requested_method",
    "requested_ttl_s",
    "mode",
    "bridge_epoch",
    "authority_bounds"
  ],
  "properties": {
    "schema_version": {
      "const": "secret-0002-0.1"
    },
    "request_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "bridge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trace",
        "witness_jti",
        "decision_effect",
        "policy_input_sha256",
        "decision_sha256",
        "deny_reasons",
        "burn_reasons"
      ],
      "properties": {
        "trace": {
          "type": "string",
          "minLength": 8,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "witness_jti": {
          "type": "string",
          "minLength": 8,
          "maxLength": 256
        },
        "decision_effect": {
          "type": "string",
          "enum": [
            "accept",
            "deny",
            "burn"
          ]
        },
        "policy_input_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "decision_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "audit_record_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "deny_reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          },
          "uniqueItems": true
        },
        "burn_reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          },
          "uniqueItems": true
        }
      }
    },
    "resource_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "binding_id",
        "requested_tool",
        "requested_resource",
        "source_domain",
        "secret_id",
        "backend_profile_id",
        "materializer_profile_id"
      ],
      "properties": {
        "binding_id": {
          "type": "string",
          "minLength": 8,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "requested_tool": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "requested_resource": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "source_domain": {
          "type": "string",
          "minLength": 3,
          "maxLength": 256,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]{2,255}$"
        },
        "destination_domain": {
          "type": "string",
          "minLength": 3,
          "maxLength": 256,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]{2,255}$"
        },
        "secret_id": {
          "type": "string",
          "minLength": 3,
          "maxLength": 256,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]{2,255}$"
        },
        "backend_profile_id": {
          "type": "string",
          "minLength": 3,
          "maxLength": 256,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]{2,255}$"
        },
        "materializer_profile_id": {
          "type": "string",
          "minLength": 3,
          "maxLength": 256,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]{2,255}$"
        },
        "issuance_mode": {
          "type": "string",
          "enum": [
            "store-and-release",
            "issue-on-demand",
            "derive-per-use",
            "proxy-only",
            "reference-only",
            "dynamic-lease"
          ]
        }
      }
    },
    "secret": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "secret_id",
        "secret_class"
      ],
      "properties": {
        "secret_id": {
          "type": "string",
          "minLength": 3,
          "maxLength": 256,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]{2,255}$"
        },
        "secret_class": {
          "type": "string",
          "enum": [
            "password",
            "api-token",
            "database-credential",
            "oauth-client-secret",
            "symmetric-key",
            "asymmetric-private-key",
            "asymmetric-keypair",
            "certificate-keypair",
            "signing-key",
            "wrapping-key",
            "recovery-share",
            "bootstrap-secret",
            "seed",
            "dynamic-credential-template"
          ]
        },
        "version_selector": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "version_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "secret_epoch_min": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2147483647
        },
        "purpose": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        }
      }
    },
    "consumer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id",
        "host_attestation"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "service",
            "systemd-unit",
            "pid",
            "k8s-pod",
            "ci-job",
            "dev-shell",
            "macos-process"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "host_attestation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "verified"
          ],
          "properties": {
            "verified": {
              "type": "boolean"
            },
            "digest": {
              "type": "string",
              "minLength": 1,
              "maxLength": 512
            }
          }
        },
        "process_attestation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "verified": {
              "type": "boolean"
            },
            "digest": {
              "type": "string",
              "minLength": 1,
              "maxLength": 512
            }
          }
        }
      }
    },
    "requested_method": {
      "type": "string",
      "enum": [
        "systemd-credential",
        "memfd-pass",
        "unix-socket-proxy",
        "tmpfs-file",
        "cloud-kms-decrypt",
        "os-keychain-ref",
        "agent-proxy"
      ]
    },
    "requested_ttl_s": {
      "type": "integer",
      "minimum": 1,
      "maximum": 31536000
    },
    "mode": {
      "type": "string",
      "enum": [
        "normal",
        "degraded",
        "safe",
        "burn"
      ]
    },
    "bridge_epoch": {
      "type": "integer",
      "minimum": 0,
      "maximum": 2147483647
    },
    "authority_bounds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "effective_ttl_s",
        "single_use",
        "max_secret_materializations",
        "non_exportable",
        "direct_model_access_prohibited",
        "allow_secrets_in_output"
      ],
      "properties": {
        "effective_ttl_s": {
          "type": "integer",
          "minimum": 1,
          "maximum": 31536000
        },
        "single_use": {
          "type": "boolean"
        },
        "max_secret_materializations": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2147483647
        },
        "non_exportable": {
          "type": "boolean"
        },
        "direct_model_access_prohibited": {
          "const": true
        },
        "allow_secrets_in_output": {
          "const": false
        },
        "return_to_model": {
          "type": "boolean"
        },
        "human_review_required": {
          "type": "boolean"
        },
        "approval_mode": {
          "type": "string",
          "enum": [
            "none",
            "single",
            "dual"
          ]
        }
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "audit_sink_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "emit_required": {
          "type": "boolean"
        }
      }
    }
  }
}

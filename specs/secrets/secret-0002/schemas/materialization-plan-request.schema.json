{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/secret-0002/materialization-plan-request.schema.json",
  "title": "SECRET-0002 Materialization Plan Request",
  "description": "Bridge-authorized request to plan a concrete materialization session under a selected backend and materializer profile.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_id",
    "bridge_trace",
    "secret_id",
    "secret_class",
    "consumer",
    "requested_method",
    "requested_ttl_s",
    "mode",
    "bridge_epoch"
  ],
  "properties": {
    "schema_version": {
      "const": "secret-0002-0.1"
    },
    "request_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "bridge_trace": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "secret_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]{2,255}$"
    },
    "secret_class": {
      "type": "string",
      "enum": [
        "password",
        "api-token",
        "database-credential",
        "oauth-client-secret",
        "symmetric-key",
        "asymmetric-private-key",
        "asymmetric-keypair",
        "certificate-keypair",
        "signing-key",
        "wrapping-key",
        "recovery-share",
        "bootstrap-secret",
        "seed",
        "dynamic-credential-template"
      ]
    },
    "consumer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id",
        "host_attestation"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "service",
            "systemd-unit",
            "pid",
            "k8s-pod",
            "ci-job",
            "dev-shell",
            "macos-process"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "host_attestation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "verified"
          ],
          "properties": {
            "verified": {
              "type": "boolean"
            },
            "digest": {
              "type": "string",
              "minLength": 1,
              "maxLength": 512
            }
          }
        },
        "process_attestation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "verified": {
              "type": "boolean"
            },
            "digest": {
              "type": "string",
              "minLength": 1,
              "maxLength": 512
            }
          }
        }
      }
    },
    "requested_method": {
      "type": "string",
      "enum": [
        "systemd-credential",
        "memfd-pass",
        "unix-socket-proxy",
        "tmpfs-file",
        "cloud-kms-decrypt",
        "os-keychain-ref",
        "agent-proxy"
      ]
    },
    "requested_ttl_s": {
      "type": "integer",
      "minimum": 1,
      "maximum": 31536000
    },
    "mode": {
      "type": "string",
      "enum": [
        "normal",
        "degraded",
        "safe",
        "burn"
      ]
    },
    "bridge_epoch": {
      "type": "integer",
      "minimum": 0,
      "maximum": 2147483647
    },
    "secret_epoch_min": {
      "type": "integer",
      "minimum": 0,
      "maximum": 2147483647
    },
    "purpose": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/secret-0002/backend-binding.schema.json",
  "title": "SECRET-0002 Backend Binding",
  "description": "Binds a logical secret class or secret id to one backend profile and one materializer profile.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "binding_id",
    "secret_id",
    "secret_class",
    "backend_profile_id",
    "materializer_profile_id",
    "issuance_mode",
    "direct_model_access_prohibited",
    "non_exportable",
    "handle_binding",
    "allowed_actions",
    "allowed_modes"
  ],
  "properties": {
    "schema_version": {
      "const": "secret-0002-0.1"
    },
    "binding_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "secret_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]{2,255}$"
    },
    "secret_class": {
      "type": "string",
      "enum": [
        "password",
        "api-token",
        "database-credential",
        "oauth-client-secret",
        "symmetric-key",
        "asymmetric-private-key",
        "asymmetric-keypair",
        "certificate-keypair",
        "signing-key",
        "wrapping-key",
        "recovery-share",
        "bootstrap-secret",
        "seed",
        "dynamic-credential-template"
      ]
    },
    "backend_profile_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]{2,255}$"
    },
    "materializer_profile_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]{2,255}$"
    },
    "issuance_mode": {
      "type": "string",
      "enum": [
        "store-and-release",
        "issue-on-demand",
        "derive-per-use",
        "proxy-only",
        "reference-only"
      ]
    },
    "reference_kind": {
      "type": "string",
      "enum": [
        "ciphertext-ref",
        "lease-ref",
        "signing-ref",
        "kms-key-id",
        "keychain-ref",
        "opaque"
      ]
    },
    "direct_model_access_prohibited": {
      "type": "boolean",
      "const": true
    },
    "non_exportable": {
      "type": "boolean"
    },
    "max_ttl_s_override": {
      "type": "integer",
      "minimum": 1,
      "maximum": 31536000
    },
    "allowed_actions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128
      }
    },
    "allowed_modes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "normal",
          "degraded",
          "safe"
        ]
      }
    },
    "burn_closes_sessions": {
      "type": "boolean",
      "default": true
    },
    "handle_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "consumer_kind",
        "node_scope",
        "bridge_required"
      ],
      "properties": {
        "consumer_kind": {
          "type": "string",
          "enum": [
            "service",
            "systemd-unit",
            "pid",
            "k8s-pod",
            "ci-job",
            "dev-shell",
            "macos-process"
          ]
        },
        "consumer_id_pattern": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "node_scope": {
          "type": "string",
          "enum": [
            "same-process",
            "same-host",
            "same-pod",
            "same-user-session"
          ]
        },
        "bridge_required": {
          "type": "boolean"
        }
      }
    },
    "policy_overrides": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "require_host_attestation": {
          "type": "boolean"
        },
        "require_process_attestation": {
          "type": "boolean"
        },
        "allow_local_cache": {
          "type": "boolean"
        },
        "restore_dual_authorization": {
          "type": "boolean"
        }
      }
    }
  }
}

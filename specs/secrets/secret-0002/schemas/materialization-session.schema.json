{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/secret-0002/materialization-session.schema.json",
  "title": "SECRET-0002 Materialization Session",
  "description": "Concrete execution plan or issued session for a secret materialization path. Raw secret values are intentionally excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "session_id",
    "decision",
    "session_state",
    "bridge_trace",
    "secret_id",
    "secret_class",
    "backend_profile_id",
    "materializer_profile_id",
    "consumer",
    "mode",
    "session_epoch",
    "issued_at",
    "expires_at",
    "handle",
    "constraints"
  ],
  "properties": {
    "schema_version": {
      "const": "secret-0002-0.1"
    },
    "session_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "decision": {
      "type": "string",
      "enum": [
        "allow",
        "deny"
      ]
    },
    "session_state": {
      "type": "string",
      "enum": [
        "planned",
        "issued",
        "revoked",
        "expired",
        "denied",
        "torn_down"
      ]
    },
    "bridge_trace": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "request_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "secret_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]{2,255}$"
    },
    "secret_class": {
      "type": "string",
      "enum": [
        "password",
        "api-token",
        "database-credential",
        "oauth-client-secret",
        "symmetric-key",
        "asymmetric-private-key",
        "asymmetric-keypair",
        "certificate-keypair",
        "signing-key",
        "wrapping-key",
        "recovery-share",
        "bootstrap-secret",
        "seed",
        "dynamic-credential-template"
      ]
    },
    "backend_profile_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]{2,255}$"
    },
    "materializer_profile_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]{2,255}$"
    },
    "consumer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "service",
            "systemd-unit",
            "pid",
            "k8s-pod",
            "ci-job",
            "dev-shell",
            "macos-process"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        }
      }
    },
    "mode": {
      "type": "string",
      "enum": [
        "normal",
        "degraded",
        "safe",
        "burn"
      ]
    },
    "session_epoch": {
      "type": "integer",
      "minimum": 0,
      "maximum": 2147483647
    },
    "secret_epoch": {
      "type": "integer",
      "minimum": 0,
      "maximum": 2147483647
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "backend_operation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "issue-dynamic",
            "decrypt-reference",
            "lookup-reference",
            "sign-proxy",
            "unwrap",
            "none"
          ]
        },
        "ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        }
      }
    },
    "handle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "ref"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "credential-file",
            "fd-name",
            "socket-ref",
            "kms-op-ref",
            "keychain-ref",
            "opaque-handle",
            "deny"
          ]
        },
        "ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        }
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128
      }
    },
    "revalidation_triggers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128
      },
      "uniqueItems": true
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "non_exportable",
        "model_reentry_prohibited",
        "log_redaction_required",
        "destroy_on_exit"
      ],
      "properties": {
        "non_exportable": {
          "type": "boolean"
        },
        "model_reentry_prohibited": {
          "type": "boolean"
        },
        "log_redaction_required": {
          "type": "boolean"
        },
        "destroy_on_exit": {
          "type": "boolean"
        }
      }
    },
    "teardown_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128
      }
    },
    "deny_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 256
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "decision": {
            "const": "deny"
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "required": [
          "deny_reasons"
        ],
        "properties": {
          "session_state": {
            "const": "denied"
          },
          "handle": {
            "properties": {
              "kind": {
                "const": "deny"
              }
            }
          }
        }
      }
    }
  ]
}

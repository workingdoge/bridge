{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/secret-0002/backend-profile.schema.json",
  "title": "SECRET-0002 Backend Profile",
  "description": "Concrete backend trust and storage profile for a class of secrets. Raw plaintext secret values are intentionally excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile_id",
    "backend_type",
    "allowed_secret_classes",
    "trust_boundary",
    "protection",
    "revocation",
    "recovery",
    "capabilities",
    "audit"
  ],
  "properties": {
    "schema_version": {
      "const": "secret-0002-0.1"
    },
    "profile_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]{2,255}$"
    },
    "display_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "backend_type": {
      "type": "string",
      "enum": [
        "hsm-rooted",
        "kms-envelope",
        "vault-dynamic",
        "external-reference",
        "os-keychain-bootstrap"
      ]
    },
    "allowed_secret_classes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "password",
          "api-token",
          "database-credential",
          "oauth-client-secret",
          "symmetric-key",
          "asymmetric-private-key",
          "asymmetric-keypair",
          "certificate-keypair",
          "signing-key",
          "wrapping-key",
          "recovery-share",
          "bootstrap-secret",
          "seed",
          "dynamic-credential-template"
        ]
      }
    },
    "trust_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "locality",
        "attestation_required"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "hsm",
            "cloud-kms",
            "vault-cluster",
            "remote-signer",
            "os-keychain",
            "tee",
            "managed-kms"
          ]
        },
        "locality": {
          "type": "string",
          "enum": [
            "local",
            "remote",
            "hybrid"
          ]
        },
        "attestation_required": {
          "type": "boolean"
        },
        "attestation_provider": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "freshness_s": {
          "type": "integer",
          "minimum": 0,
          "maximum": 31536000
        }
      }
    },
    "protection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "module_validation",
        "export_policy",
        "storage_mode",
        "root_key_online",
        "plaintext_persisted"
      ],
      "properties": {
        "module_validation": {
          "type": "string",
          "enum": [
            "none",
            "fips140-3-level1",
            "fips140-3-level2",
            "fips140-3-level3",
            "fips140-3-level4",
            "vendor-asserted"
          ]
        },
        "export_policy": {
          "type": "string",
          "enum": [
            "non-exportable",
            "wrapped-only",
            "plaintext-disallowed",
            "reference-only"
          ]
        },
        "storage_mode": {
          "type": "string",
          "enum": [
            "ciphertext-at-rest",
            "dynamic-issued",
            "reference-only",
            "hardware-sealed"
          ]
        },
        "root_key_online": {
          "type": "boolean"
        },
        "plaintext_persisted": {
          "type": "boolean",
          "const": false
        },
        "wrap_algorithms": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          },
          "uniqueItems": true
        },
        "notes": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        }
      }
    },
    "revocation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mechanism",
        "max_propagation_s"
      ],
      "properties": {
        "mechanism": {
          "type": "string",
          "enum": [
            "epoch",
            "lease",
            "callback",
            "version-disable",
            "key-disable"
          ]
        },
        "max_propagation_s": {
          "type": "integer",
          "minimum": 0,
          "maximum": 31536000
        }
      }
    },
    "recovery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recoverable",
        "backup_mode",
        "dual_control_required",
        "alternate_site_required"
      ],
      "properties": {
        "recoverable": {
          "type": "boolean"
        },
        "backup_mode": {
          "type": "string",
          "enum": [
            "none",
            "encrypted-backup",
            "quorum-shares",
            "vendor-managed"
          ]
        },
        "dual_control_required": {
          "type": "boolean"
        },
        "alternate_site_required": {
          "type": "boolean"
        }
      }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "generate",
          "import",
          "derive",
          "unwrap",
          "decrypt",
          "sign",
          "issue-dynamic",
          "lookup-reference",
          "revoke-lease",
          "disable-version",
          "disable-key"
        ]
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "backend_events_required",
        "authoritative_time_required"
      ],
      "properties": {
        "backend_events_required": {
          "type": "boolean"
        },
        "authoritative_time_required": {
          "type": "boolean"
        }
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bootstrap_only": {
          "type": "boolean"
        },
        "shared_infra_allowed": {
          "type": "boolean"
        },
        "local_cache_allowed": {
          "type": "boolean"
        },
        "allow_plaintext_export": {
          "type": "boolean",
          "const": false
        }
      }
    }
  }
}

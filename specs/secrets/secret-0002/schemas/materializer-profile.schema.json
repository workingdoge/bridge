{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/secret-0002/materializer-profile.schema.json",
  "title": "SECRET-0002 Materializer Profile",
  "description": "Concrete last-mile delivery profile for secret handles or bounded plaintext surfaces. Raw secret values are intentionally excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile_id",
    "materializer_type",
    "platform",
    "handle_kind",
    "plaintext_surface",
    "allowed_secret_classes",
    "default_ttl_s",
    "max_ttl_s",
    "consumer_binding_required",
    "revalidation",
    "teardown",
    "model_reentry_prohibited",
    "log_redaction_required",
    "env_var_allowed"
  ],
  "properties": {
    "schema_version": {
      "const": "secret-0002-0.1"
    },
    "profile_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]{2,255}$"
    },
    "display_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "materializer_type": {
      "type": "string",
      "enum": [
        "systemd-credential",
        "memfd-pass",
        "unix-socket-proxy",
        "tmpfs-file",
        "cloud-kms-decrypt",
        "os-keychain-ref",
        "agent-proxy"
      ]
    },
    "platform": {
      "type": "string",
      "enum": [
        "linux-systemd",
        "linux-generic",
        "macos",
        "kubernetes",
        "cloud-native"
      ]
    },
    "handle_kind": {
      "type": "string",
      "enum": [
        "credential-file",
        "fd-name",
        "socket-ref",
        "kms-op-ref",
        "keychain-ref",
        "opaque-handle"
      ]
    },
    "plaintext_surface": {
      "type": "string",
      "enum": [
        "never",
        "file-descriptor-only",
        "tmpfs-bounded",
        "credential-dir-bounded",
        "remote-handle-only",
        "keychain-local"
      ]
    },
    "allowed_secret_classes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "password",
          "api-token",
          "database-credential",
          "oauth-client-secret",
          "symmetric-key",
          "asymmetric-private-key",
          "asymmetric-keypair",
          "certificate-keypair",
          "signing-key",
          "wrapping-key",
          "recovery-share",
          "bootstrap-secret",
          "seed",
          "dynamic-credential-template"
        ]
      }
    },
    "default_ttl_s": {
      "type": "integer",
      "minimum": 1,
      "maximum": 31536000
    },
    "max_ttl_s": {
      "type": "integer",
      "minimum": 1,
      "maximum": 31536000
    },
    "consumer_binding_required": {
      "type": "boolean"
    },
    "required_host_features": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128
      }
    },
    "revalidation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "on_bridge_burn",
        "on_secret_epoch_change",
        "on_attestation_loss",
        "on_consumer_exit"
      ],
      "properties": {
        "on_bridge_burn": {
          "type": "boolean"
        },
        "on_secret_epoch_change": {
          "type": "boolean"
        },
        "on_attestation_loss": {
          "type": "boolean"
        },
        "on_consumer_exit": {
          "type": "boolean"
        }
      }
    },
    "teardown": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "destroy_on_exit",
        "zeroize_local_plaintext",
        "revoke_on_burn"
      ],
      "properties": {
        "destroy_on_exit": {
          "type": "boolean"
        },
        "zeroize_local_plaintext": {
          "type": "boolean"
        },
        "revoke_on_burn": {
          "type": "boolean"
        },
        "unlink_files_on_exit": {
          "type": "boolean"
        }
      }
    },
    "model_reentry_prohibited": {
      "type": "boolean",
      "const": true
    },
    "log_redaction_required": {
      "type": "boolean",
      "const": true
    },
    "env_var_allowed": {
      "type": "boolean",
      "const": false
    }
  }
}

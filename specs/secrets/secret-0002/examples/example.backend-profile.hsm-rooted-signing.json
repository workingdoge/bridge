{
  "schema_version": "secret-0002-0.1",
  "profile_id": "backend.hsm-rooted-signing",
  "display_name": "HSM Rooted Signing Authority",
  "backend_type": "hsm-rooted",
  "allowed_secret_classes": [
    "signing-key"
  ],
  "trust_boundary": {
    "kind": "hsm",
    "locality": "remote",
    "attestation_required": true,
    "attestation_provider": "provider.attestation.hsm",
    "freshness_s": 300
  },
  "protection": {
    "module_validation": "fips140-3-level3",
    "export_policy": "non-exportable",
    "storage_mode": "hardware-sealed",
    "root_key_online": false,
    "plaintext_persisted": false
  },
  "revocation": {
    "mechanism": "epoch",
    "max_propagation_s": 30
  },
  "recovery": {
    "recoverable": true,
    "backup_mode": "quorum-shares",
    "dual_control_required": true,
    "alternate_site_required": true
  },
  "capabilities": [
    "sign",
    "lookup-reference",
    "disable-key"
  ],
  "audit": {
    "backend_events_required": true,
    "authoritative_time_required": true
  }
}

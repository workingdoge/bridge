{
  "schema_version": "secret-0002-0.1",
  "profile_id": "materializer.systemd-credential",
  "display_name": "systemd Credential Directory",
  "materializer_type": "systemd-credential",
  "platform": "linux-systemd",
  "handle_kind": "credential-file",
  "plaintext_surface": "credential-dir-bounded",
  "allowed_secret_classes": [
    "database-credential"
  ],
  "default_ttl_s": 120,
  "max_ttl_s": 300,
  "consumer_binding_required": true,
  "required_host_features": [
    "systemd-credentials"
  ],
  "revalidation": {
    "on_bridge_burn": true,
    "on_secret_epoch_change": true,
    "on_attestation_loss": true,
    "on_consumer_exit": true
  },
  "teardown": {
    "destroy_on_exit": true,
    "zeroize_local_plaintext": true,
    "revoke_on_burn": true,
    "unlink_files_on_exit": true
  },
  "model_reentry_prohibited": true,
  "log_redaction_required": true,
  "env_var_allowed": false
}

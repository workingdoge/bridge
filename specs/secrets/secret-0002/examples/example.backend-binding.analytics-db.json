{
  "schema_version": "secret-0002-0.1",
  "binding_id": "binding.reporting-db",
  "secret_id": "secret.analytics.reporting-db",
  "secret_class": "database-credential",
  "backend_profile_id": "backend.vault-dynamic-db",
  "materializer_profile_id": "materializer.systemd-credential",
  "issuance_mode": "issue-on-demand",
  "reference_kind": "lease-ref",
  "direct_model_access_prohibited": true,
  "non_exportable": false,
  "max_ttl_s_override": 120,
  "allowed_actions": [
    "read",
    "issue-dynamic"
  ],
  "allowed_modes": [
    "normal",
    "degraded"
  ],
  "burn_closes_sessions": true,
  "handle_binding": {
    "consumer_kind": "systemd-unit",
    "consumer_id_pattern": "^analytics-reporter\\.service$",
    "node_scope": "same-host",
    "bridge_required": true
  },
  "policy_overrides": {
    "require_host_attestation": true,
    "allow_local_cache": false
  }
}

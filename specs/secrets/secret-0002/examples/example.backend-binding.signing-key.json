{
  "schema_version": "secret-0002-0.1",
  "binding_id": "binding.release-signing-key",
  "secret_id": "secret.signing.release-artifact",
  "secret_class": "signing-key",
  "backend_profile_id": "backend.hsm-rooted-signing",
  "materializer_profile_id": "materializer.unix-socket-proxy",
  "issuance_mode": "proxy-only",
  "reference_kind": "signing-ref",
  "direct_model_access_prohibited": true,
  "non_exportable": true,
  "max_ttl_s_override": 600,
  "allowed_actions": [
    "sign"
  ],
  "allowed_modes": [
    "normal",
    "degraded",
    "safe"
  ],
  "burn_closes_sessions": true,
  "handle_binding": {
    "consumer_kind": "service",
    "consumer_id_pattern": "^release-signer$",
    "node_scope": "same-host",
    "bridge_required": true
  },
  "policy_overrides": {
    "require_host_attestation": true,
    "require_process_attestation": true
  }
}

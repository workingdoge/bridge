{
  "schema_version": "secret-0002-0.1",
  "profile_id": "materializer.unix-socket-proxy",
  "display_name": "Unix Socket Signing Proxy",
  "materializer_type": "unix-socket-proxy",
  "platform": "linux-generic",
  "handle_kind": "socket-ref",
  "plaintext_surface": "remote-handle-only",
  "allowed_secret_classes": [
    "signing-key"
  ],
  "default_ttl_s": 600,
  "max_ttl_s": 900,
  "consumer_binding_required": true,
  "required_host_features": [
    "unix-domain-sockets"
  ],
  "revalidation": {
    "on_bridge_burn": true,
    "on_secret_epoch_change": true,
    "on_attestation_loss": true,
    "on_consumer_exit": true
  },
  "teardown": {
    "destroy_on_exit": true,
    "zeroize_local_plaintext": true,
    "revoke_on_burn": true,
    "unlink_files_on_exit": true
  },
  "model_reentry_prohibited": true,
  "log_redaction_required": true,
  "env_var_allowed": false
}

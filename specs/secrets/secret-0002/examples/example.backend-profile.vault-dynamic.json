{
  "schema_version": "secret-0002-0.1",
  "profile_id": "backend.vault-dynamic-db",
  "display_name": "Vault Dynamic Database Credentials",
  "backend_type": "vault-dynamic",
  "allowed_secret_classes": [
    "database-credential"
  ],
  "trust_boundary": {
    "kind": "vault-cluster",
    "locality": "remote",
    "attestation_required": true,
    "attestation_provider": "provider.attestation.main",
    "freshness_s": 300
  },
  "protection": {
    "module_validation": "vendor-asserted",
    "export_policy": "plaintext-disallowed",
    "storage_mode": "dynamic-issued",
    "root_key_online": false,
    "plaintext_persisted": false,
    "notes": "Dynamic database leases are issued on demand and never stored as durable plaintext metadata."
  },
  "revocation": {
    "mechanism": "lease",
    "max_propagation_s": 60
  },
  "recovery": {
    "recoverable": true,
    "backup_mode": "vendor-managed",
    "dual_control_required": false,
    "alternate_site_required": false
  },
  "capabilities": [
    "issue-dynamic",
    "lookup-reference",
    "revoke-lease"
  ],
  "audit": {
    "backend_events_required": true,
    "authoritative_time_required": true
  }
}

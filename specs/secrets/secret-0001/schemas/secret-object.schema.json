{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/secret-0001/secret-object.schema.json",
  "title": "SECRET-0001 Secret Object",
  "description": "Canonical metadata for one logical secret and its versions. Plaintext secret values are intentionally excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "secret_id",
    "secret_class",
    "owner",
    "domain",
    "conf_label",
    "integ_label",
    "origin",
    "lifecycle_policy",
    "materialization_policy",
    "recovery_policy",
    "versions",
    "audit"
  ],
  "properties": {
    "schema_version": {
      "const": "secret-0001-0.1"
    },
    "secret_id": {
      "$ref": "#/$defs/idToken"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048
    },
    "secret_class": {
      "type": "string",
      "enum": [
        "password",
        "api-token",
        "database-credential",
        "oauth-client-secret",
        "symmetric-key",
        "asymmetric-private-key",
        "asymmetric-keypair",
        "certificate-keypair",
        "signing-key",
        "wrapping-key",
        "recovery-share",
        "bootstrap-secret",
        "seed",
        "dynamic-credential-template"
      ]
    },
    "owner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "admin_group",
        "service_owner"
      ],
      "properties": {
        "admin_group": {
          "$ref": "#/$defs/idToken"
        },
        "service_owner": {
          "$ref": "#/$defs/idToken"
        },
        "custodian_group": {
          "$ref": "#/$defs/idToken"
        }
      }
    },
    "domain": {
      "$ref": "#/$defs/idToken"
    },
    "conf_label": {
      "$ref": "#/$defs/securityLabel"
    },
    "integ_label": {
      "$ref": "#/$defs/securityLabel"
    },
    "origin": {
      "type": "string",
      "enum": [
        "generated",
        "imported",
        "derived",
        "external-reference",
        "recovered"
      ]
    },
    "bridge_binding": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": {
          "type": "boolean"
        },
        "witness_profile": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "break_glass_profile": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      }
    },
    "lifecycle_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rotation_mode",
        "max_active_age_s",
        "max_overlap_s",
        "activation_requirements",
        "revocation_sla_s"
      ],
      "properties": {
        "rotation_mode": {
          "type": "string",
          "enum": [
            "manual",
            "scheduled",
            "on-demand",
            "derived-per-use"
          ]
        },
        "max_active_age_s": {
          "type": "integer",
          "minimum": 1,
          "maximum": 315360000
        },
        "max_overlap_s": {
          "type": "integer",
          "minimum": 0,
          "maximum": 315360000
        },
        "max_simultaneous_active_versions": {
          "type": "integer",
          "minimum": 1,
          "maximum": 8,
          "default": 1
        },
        "activation_requirements": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "attestation_required",
            "approval_mode"
          ],
          "properties": {
            "attestation_required": {
              "type": "boolean"
            },
            "approval_mode": {
              "type": "string",
              "enum": [
                "none",
                "single",
                "dual"
              ]
            },
            "issuer_profile": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            }
          }
        },
        "revocation_sla_s": {
          "type": "integer",
          "minimum": 0,
          "maximum": 31536000
        },
        "archive_after_s": {
          "type": "integer",
          "minimum": 0,
          "maximum": 315360000
        },
        "destroy_after_s": {
          "type": "integer",
          "minimum": 0,
          "maximum": 315360000
        }
      }
    },
    "materialization_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_methods",
        "max_ttl_s",
        "bind_to_consumer",
        "exportable",
        "reentry_to_model_prohibited",
        "log_export_prohibited"
      ],
      "properties": {
        "allowed_methods": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "fd-pass",
              "memfd",
              "unix-socket",
              "tmpfs-file",
              "agent-proxy",
              "cloud-kms-decrypt",
              "os-keychain-ref",
              "env-var"
            ]
          }
        },
        "max_ttl_s": {
          "type": "integer",
          "minimum": 1,
          "maximum": 31536000
        },
        "bind_to_consumer": {
          "type": "boolean"
        },
        "exportable": {
          "type": "boolean"
        },
        "destroy_on_consumer_exit": {
          "type": "boolean",
          "default": true
        },
        "reentry_to_model_prohibited": {
          "type": "boolean"
        },
        "log_export_prohibited": {
          "type": "boolean"
        },
        "allowed_consumers": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "service",
              "systemd-unit",
              "pid",
              "k8s-pod",
              "ci-job",
              "dev-shell",
              "macos-process"
            ]
          }
        }
      }
    },
    "recovery_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recoverable",
        "backup_required",
        "alternate_storage_required"
      ],
      "properties": {
        "recoverable": {
          "type": "boolean"
        },
        "backup_required": {
          "type": "boolean"
        },
        "alternate_storage_required": {
          "type": "boolean"
        },
        "escrow_mode": {
          "type": "string",
          "enum": [
            "none",
            "encrypted-copy",
            "split-knowledge",
            "quorum-shares"
          ]
        },
        "quorum_k": {
          "type": "integer",
          "minimum": 1,
          "maximum": 32
        },
        "quorum_n": {
          "type": "integer",
          "minimum": 1,
          "maximum": 32
        },
        "restore_approval_mode": {
          "type": "string",
          "enum": [
            "none",
            "single",
            "dual"
          ]
        },
        "restore_enters_state": {
          "type": "string",
          "const": "staged"
        }
      }
    },
    "tags": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64,
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "versions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/secretVersion"
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "created_at",
        "created_by",
        "trace_root"
      ],
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "created_by": {
          "$ref": "#/$defs/idToken"
        },
        "trace_root": {
          "$ref": "#/$defs/tokenId"
        },
        "last_event_id": {
          "$ref": "#/$defs/tokenId"
        },
        "evidence_stream": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "recovery_policy": {
            "properties": {
              "recoverable": {
                "const": true
              }
            },
            "required": [
              "recoverable"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "recovery_policy": {
            "required": [
              "restore_approval_mode"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "recovery_policy": {
            "properties": {
              "escrow_mode": {
                "enum": [
                  "split-knowledge",
                  "quorum-shares"
                ]
              }
            },
            "required": [
              "escrow_mode"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "recovery_policy": {
            "required": [
              "quorum_k",
              "quorum_n"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "secret_class": {
            "enum": [
              "wrapping-key",
              "recovery-share"
            ]
          }
        },
        "required": [
          "secret_class"
        ]
      },
      "then": {
        "properties": {
          "recovery_policy": {
            "properties": {
              "restore_approval_mode": {
                "enum": [
                  "dual"
                ]
              }
            },
            "required": [
              "restore_approval_mode"
            ]
          }
        }
      }
    }
  ],
  "$defs": {
    "idToken": {
      "type": "string",
      "minLength": 3,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]{2,255}$"
    },
    "tokenId": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "securityLabel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level"
      ],
      "properties": {
        "level": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "compartments": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "pattern": "^[A-Za-z0-9._:-]+$"
          }
        },
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "pattern": "^[A-Za-z0-9._:-]+$"
          }
        },
        "marking": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      }
    },
    "digestRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "alg",
        "value"
      ],
      "properties": {
        "alg": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "value": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        }
      }
    },
    "secretVersion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version_id",
        "state",
        "epoch",
        "created_at",
        "cryptoperiod_s",
        "provenance",
        "storage_ref",
        "protection",
        "revocation"
      ],
      "properties": {
        "version_id": {
          "$ref": "#/$defs/tokenId"
        },
        "state": {
          "type": "string",
          "enum": [
            "staged",
            "active",
            "suspended",
            "revoked",
            "retired",
            "archived",
            "destroyed"
          ]
        },
        "epoch": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2147483647
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "not_before": {
          "type": "string",
          "format": "date-time"
        },
        "activated_at": {
          "type": "string",
          "format": "date-time"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        },
        "revoked_at": {
          "type": "string",
          "format": "date-time"
        },
        "destroyed_at": {
          "type": "string",
          "format": "date-time"
        },
        "cryptoperiod_s": {
          "type": "integer",
          "minimum": 1,
          "maximum": 315360000
        },
        "provenance": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "generated",
                "imported",
                "derived",
                "restored",
                "external"
              ]
            },
            "generator": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256
            },
            "source_ref": {
              "type": "string",
              "minLength": 1,
              "maxLength": 512
            },
            "attestation_digest": {
              "$ref": "#/$defs/digestRef"
            }
          }
        },
        "storage_ref": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "backend",
            "locator",
            "plaintext_persisted"
          ],
          "properties": {
            "backend": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            },
            "locator": {
              "type": "string",
              "minLength": 1,
              "maxLength": 512
            },
            "ciphertext_ref": {
              "type": "string",
              "minLength": 1,
              "maxLength": 512
            },
            "plaintext_persisted": {
              "type": "boolean",
              "const": false
            }
          }
        },
        "protection": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mode"
          ],
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "wrapped",
                "hsm-backed",
                "kms-backed",
                "external-ref",
                "derived-per-use"
              ]
            },
            "module_boundary": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            },
            "kek_ref": {
              "type": "string",
              "minLength": 1,
              "maxLength": 512
            },
            "algorithm_suite": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            }
          }
        },
        "revocation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "authority",
            "channel",
            "max_propagation_s"
          ],
          "properties": {
            "authority": {
              "$ref": "#/$defs/idToken"
            },
            "channel": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            },
            "max_propagation_s": {
              "type": "integer",
              "minimum": 0,
              "maximum": 31536000
            },
            "revocation_epoch": {
              "type": "integer",
              "minimum": 0,
              "maximum": 2147483647
            }
          }
        },
        "retention_basis": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "notes": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "state": {
                "const": "active"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "required": [
              "activated_at"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "revoked"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "required": [
              "revoked_at"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "destroyed"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "required": [
              "destroyed_at"
            ]
          }
        }
      ]
    }
  }
}
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/secret-0001/materialization-request.schema.json",
  "title": "SECRET-0001 Materialization Request",
  "description": "Request to locally materialize a secret version or a derived lease. Raw secret values are never included.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_id",
    "bridge_trace",
    "bridge_witness_jti",
    "secret_id",
    "consumer",
    "requested_method",
    "requested_ttl_s",
    "mode"
  ],
  "properties": {
    "schema_version": {
      "const": "secret-0001-0.1"
    },
    "request_id": {
      "$ref": "#/$defs/tokenId"
    },
    "bridge_trace": {
      "$ref": "#/$defs/tokenId"
    },
    "bridge_witness_jti": {
      "$ref": "#/$defs/tokenId"
    },
    "secret_id": {
      "$ref": "#/$defs/idToken"
    },
    "version_selector": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "version_id": {
          "$ref": "#/$defs/tokenId"
        },
        "state": {
          "type": "string",
          "enum": [
            "active"
          ]
        },
        "epoch_min": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2147483647
        }
      }
    },
    "consumer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id",
        "host_attestation"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "service",
            "systemd-unit",
            "pid",
            "k8s-pod",
            "ci-job",
            "dev-shell",
            "macos-process"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "host_attestation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "verified"
          ],
          "properties": {
            "verified": {
              "type": "boolean"
            },
            "digest": {
              "type": "string",
              "minLength": 1,
              "maxLength": 512
            }
          }
        },
        "process_attestation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "verified": {
              "type": "boolean"
            },
            "digest": {
              "type": "string",
              "minLength": 1,
              "maxLength": 512
            }
          }
        }
      }
    },
    "requested_method": {
      "type": "string",
      "enum": [
        "fd-pass",
        "memfd",
        "unix-socket",
        "tmpfs-file",
        "agent-proxy",
        "cloud-kms-decrypt",
        "os-keychain-ref",
        "env-var"
      ]
    },
    "requested_ttl_s": {
      "type": "integer",
      "minimum": 1,
      "maximum": 31536000
    },
    "mode": {
      "type": "string",
      "enum": [
        "normal",
        "degraded",
        "safe",
        "burn"
      ]
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "node_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "pid": {
          "type": "integer",
          "minimum": 1
        },
        "session_nonce": {
          "type": "string",
          "minLength": 8,
          "maxLength": 256
        },
        "purpose": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        }
      }
    }
  },
  "$defs": {
    "idToken": {
      "type": "string",
      "minLength": 3,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]{2,255}$"
    },
    "tokenId": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    }
  }
}
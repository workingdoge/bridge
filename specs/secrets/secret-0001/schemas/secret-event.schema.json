{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/secret-0001/secret-event.schema.json",
  "title": "SECRET-0001 Secret Lifecycle Event",
  "description": "Audit-grade event for secret lifecycle and materialization actions. Plaintext values are intentionally excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "event_type",
    "secret_id",
    "occurred_at",
    "actor",
    "trace"
  ],
  "properties": {
    "schema_version": {
      "const": "secret-0001-0.1"
    },
    "event_id": {
      "$ref": "#/$defs/tokenId"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "register",
        "generate",
        "import",
        "derive",
        "activate",
        "suspend",
        "unsuspend",
        "rotate",
        "revoke",
        "retire",
        "archive",
        "restore",
        "destroy",
        "materialize",
        "materialization-expire",
        "materialization-revoke",
        "rewrap"
      ]
    },
    "secret_id": {
      "$ref": "#/$defs/idToken"
    },
    "version_id": {
      "$ref": "#/$defs/tokenId"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subject",
        "actor_type"
      ],
      "properties": {
        "subject": {
          "$ref": "#/$defs/idToken"
        },
        "actor_type": {
          "type": "string",
          "enum": [
            "human",
            "workload",
            "system"
          ]
        },
        "act_for": {
          "$ref": "#/$defs/idToken"
        }
      }
    },
    "trace": {
      "$ref": "#/$defs/tokenId"
    },
    "bridge_trace": {
      "$ref": "#/$defs/tokenId"
    },
    "reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "approval_mode": {
      "type": "string",
      "enum": [
        "none",
        "single",
        "dual"
      ]
    },
    "approvals": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "approver",
          "decision",
          "at"
        ],
        "properties": {
          "approver": {
            "$ref": "#/$defs/idToken"
          },
          "decision": {
            "type": "string",
            "enum": [
              "approved",
              "denied"
            ]
          },
          "at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "attestation_digest": {
      "$ref": "#/$defs/digestRef"
    },
    "details": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "from_state": {
          "type": "string",
          "enum": [
            "staged",
            "active",
            "suspended",
            "revoked",
            "retired",
            "archived",
            "destroyed"
          ]
        },
        "to_state": {
          "type": "string",
          "enum": [
            "staged",
            "active",
            "suspended",
            "revoked",
            "retired",
            "archived",
            "destroyed"
          ]
        },
        "consumer": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "method": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "ttl_s": {
          "type": "integer",
          "minimum": 1,
          "maximum": 31536000
        },
        "epoch": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2147483647
        },
        "storage_ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        }
      }
    }
  },
  "$defs": {
    "idToken": {
      "type": "string",
      "minLength": 3,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]{2,255}$"
    },
    "tokenId": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "digestRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "alg",
        "value"
      ],
      "properties": {
        "alg": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "value": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        }
      }
    }
  }
}
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/secret-0001/materialization-grant.schema.json",
  "title": "SECRET-0001 Materialization Grant",
  "description": "A local, bounded grant to materialize or indirectly consume a secret version. Raw secret values are never included.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "grant_id",
    "decision",
    "bridge_trace",
    "secret_id",
    "version_id",
    "secret_epoch",
    "method",
    "handle",
    "consumer",
    "issued_at",
    "expires_at",
    "exportable",
    "destroy_on_consumer_exit"
  ],
  "properties": {
    "schema_version": {
      "const": "secret-0001-0.1"
    },
    "grant_id": {
      "$ref": "#/$defs/tokenId"
    },
    "decision": {
      "type": "string",
      "enum": [
        "allow",
        "deny"
      ]
    },
    "bridge_trace": {
      "$ref": "#/$defs/tokenId"
    },
    "bridge_witness_jti": {
      "$ref": "#/$defs/tokenId"
    },
    "secret_id": {
      "$ref": "#/$defs/idToken"
    },
    "version_id": {
      "$ref": "#/$defs/tokenId"
    },
    "secret_epoch": {
      "type": "integer",
      "minimum": 1,
      "maximum": 2147483647
    },
    "bridge_epoch": {
      "type": "integer",
      "minimum": 0,
      "maximum": 2147483647
    },
    "method": {
      "type": "string",
      "enum": [
        "fd-pass",
        "memfd",
        "unix-socket",
        "tmpfs-file",
        "agent-proxy",
        "cloud-kms-decrypt",
        "os-keychain-ref",
        "env-var"
      ]
    },
    "handle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "ref"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "opaque-handle",
            "fd-name",
            "socket-path",
            "tmpfs-path",
            "kms-operation-ref",
            "keychain-ref"
          ]
        },
        "ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        }
      }
    },
    "consumer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "service",
            "systemd-unit",
            "pid",
            "k8s-pod",
            "ci-job",
            "dev-shell",
            "macos-process"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        }
      }
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "exportable": {
      "type": "boolean",
      "const": false
    },
    "destroy_on_consumer_exit": {
      "type": "boolean"
    },
    "audit_event_id": {
      "$ref": "#/$defs/tokenId"
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "one_time": {
          "type": "boolean"
        },
        "refresh_prohibited": {
          "type": "boolean"
        },
        "model_reentry_prohibited": {
          "type": "boolean"
        },
        "log_export_prohibited": {
          "type": "boolean"
        }
      }
    },
    "deny_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 256
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "decision": {
            "const": "deny"
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "required": [
          "deny_reasons"
        ],
        "properties": {
          "handle": {
            "properties": {
              "ref": {
                "const": "deny"
              }
            },
            "required": [
              "ref"
            ]
          }
        }
      }
    }
  ],
  "$defs": {
    "idToken": {
      "type": "string",
      "minLength": 3,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]{2,255}$"
    },
    "tokenId": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    }
  }
}
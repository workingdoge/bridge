{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "secret-overlap.schema.json",
  "title": "SecretOverlap",
  "description": "Explicit bridge-to-secret seam.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "secret_id": {
      "type": "string",
      "minLength": 1
    },
    "secret_class": {
      "type": "string",
      "minLength": 1
    },
    "version_selector": {
      "type": "string",
      "minLength": 1
    },
    "version_id": {
      "type": "string",
      "minLength": 1
    },
    "secret_epoch": {
      "oneOf": [
        {
          "type": "integer"
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "binding_id": {
      "type": "string",
      "minLength": 1
    },
    "requested_resource": {
      "type": "string",
      "minLength": 1
    },
    "backend_profile_id": {
      "type": "string",
      "minLength": 1
    },
    "materializer_profile_id": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "secret_id",
    "secret_class",
    "binding_id",
    "requested_resource",
    "backend_profile_id",
    "materializer_profile_id"
  ]
}

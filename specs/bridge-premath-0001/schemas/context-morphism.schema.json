{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "context-morphism.schema.json",
  "title": "ContextMorphism",
  "description": "Admissible refinement morphism from a narrower context (domain) to a broader context (codomain). Restore is intentionally not represented as an ordinary pullback morphism.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "const": "bridge-premath-0001-0.1"
    },
    "morphism_id": {
      "type": "string",
      "minLength": 1
    },
    "domain_context_id": {
      "type": "string",
      "minLength": 1
    },
    "codomain_context_id": {
      "type": "string",
      "minLength": 1
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "op": {
            "type": "string",
            "enum": [
              "tighten_request_scope",
              "reduce_ttl",
              "tighten_conf_label",
              "tighten_integ_label",
              "select_secret_version",
              "restrict_binding",
              "narrow_allowed_modes",
              "refresh_facts",
              "advance_mode_to_safe",
              "advance_mode_to_burn",
              "prefix_audit_stream",
              "project_chart"
            ]
          },
          "chart_id": {
            "type": "string",
            "enum": [
              "bridge",
              "secret-core",
              "materialization",
              "provider-plane",
              "audit"
            ]
          },
          "before": {},
          "after": {},
          "note": {
            "type": "string"
          }
        },
        "required": [
          "op"
        ]
      }
    },
    "invariants": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "authority_not_widened": {
          "type": "boolean",
          "const": true
        },
        "ttl_nonincreasing": {
          "type": "boolean",
          "const": true
        },
        "freshness_nonstale": {
          "type": "boolean",
          "const": true
        },
        "burn_monotone": {
          "type": "boolean",
          "const": true
        },
        "plaintext_not_globalized": {
          "type": "boolean",
          "const": true
        }
      },
      "required": [
        "authority_not_widened",
        "ttl_nonincreasing",
        "freshness_nonstale",
        "burn_monotone",
        "plaintext_not_globalized"
      ]
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "version",
    "morphism_id",
    "domain_context_id",
    "codomain_context_id",
    "operations",
    "invariants"
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "premath-context.schema.json",
  "title": "PremathContext",
  "description": "Shared admissible execution context for the Bridge + Secret Suite Premath profile.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "const": "bridge-premath-0001-0.1"
    },
    "context_id": {
      "type": "string",
      "minLength": 1
    },
    "coherence_level": {
      "type": "string",
      "enum": [
        "Set",
        "Gpd",
        "Cat",
        "S_infinity"
      ]
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "trace": {
          "type": "string",
          "minLength": 1
        },
        "witness_jti": {
          "type": "string",
          "minLength": 1
        },
        "witness_type": {
          "type": "string",
          "minLength": 1
        },
        "requested_tool": {
          "type": "string",
          "minLength": 1
        },
        "requested_resource": {
          "type": "string",
          "minLength": 1
        },
        "source_domain": {
          "type": "string",
          "minLength": 1
        },
        "destination_domain": {
          "type": "string",
          "minLength": 1
        },
        "subject_id": {
          "type": "string",
          "minLength": 1
        },
        "act_for": {
          "type": "string"
        },
        "consumer_kind": {
          "type": "string",
          "minLength": 1
        },
        "consumer_id": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "request_id",
        "trace",
        "witness_jti",
        "witness_type",
        "requested_tool",
        "requested_resource",
        "source_domain",
        "destination_domain",
        "subject_id",
        "consumer_kind",
        "consumer_id"
      ]
    },
    "secret": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "secret_id": {
          "type": "string",
          "minLength": 1
        },
        "secret_class": {
          "type": "string",
          "minLength": 1
        },
        "version_selector": {
          "type": "string",
          "minLength": 1
        },
        "version_id": {
          "type": "string",
          "minLength": 1
        },
        "secret_epoch": {
          "oneOf": [
            {
              "type": "integer"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "bridge_binding_required": {
          "type": "boolean"
        }
      },
      "required": [
        "secret_id",
        "secret_class"
      ]
    },
    "resource_secret_binding": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "binding_id": {
          "type": "string",
          "minLength": 1
        },
        "resource_basis": {
          "type": "string",
          "minLength": 1
        },
        "requested_resource": {
          "type": "string",
          "minLength": 1
        },
        "secret_id": {
          "type": "string",
          "minLength": 1
        },
        "backend_profile_id": {
          "type": "string",
          "minLength": 1
        },
        "materializer_profile_id": {
          "type": "string",
          "minLength": 1
        },
        "issuance_mode": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "binding_id",
        "resource_basis",
        "requested_resource",
        "secret_id",
        "backend_profile_id",
        "materializer_profile_id",
        "issuance_mode"
      ]
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requested_method": {
          "type": "string",
          "minLength": 1
        },
        "requested_ttl_s": {
          "type": "integer",
          "minimum": 0
        },
        "mode": {
          "type": "string",
          "enum": [
            "normal",
            "degraded",
            "safe",
            "burn",
            "restoring"
          ]
        },
        "conf_level": {
          "type": "string",
          "minLength": 1
        },
        "compartments": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "integ_level": {
          "type": "string",
          "minLength": 1
        },
        "non_exportable": {
          "type": "boolean"
        },
        "direct_model_access_prohibited": {
          "type": "boolean"
        }
      },
      "required": [
        "requested_method",
        "requested_ttl_s",
        "mode",
        "conf_level",
        "integ_level",
        "non_exportable",
        "direct_model_access_prohibited"
      ]
    },
    "provider_facts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "deployment_profile_id": {
          "type": "string",
          "minLength": 1
        },
        "provider_catalog_id": {
          "type": "string",
          "minLength": 1
        },
        "time_source_id": {
          "type": "string",
          "minLength": 1
        },
        "authoritative_now": {
          "type": "string",
          "format": "date-time"
        },
        "attestation_id": {
          "type": "string",
          "minLength": 1
        },
        "posture_digest": {
          "type": "string",
          "minLength": 1
        },
        "revocation_snapshot_id": {
          "type": "string",
          "minLength": 1
        },
        "issuer_epoch": {
          "oneOf": [
            {
              "type": "integer"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "mode_controller_id": {
          "type": "string",
          "minLength": 1
        },
        "mode_epoch": {
          "oneOf": [
            {
              "type": "integer"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "audit_sink_id": {
          "type": "string",
          "minLength": 1
        },
        "facts_fresh_until": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "deployment_profile_id",
        "provider_catalog_id",
        "time_source_id",
        "authoritative_now",
        "attestation_id",
        "posture_digest",
        "revocation_snapshot_id",
        "issuer_epoch",
        "mode_controller_id",
        "mode_epoch",
        "audit_sink_id"
      ]
    },
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "binding_id": {
          "type": "string",
          "minLength": 1
        },
        "backend_profile_id": {
          "type": "string",
          "minLength": 1
        },
        "materializer_profile_id": {
          "type": "string",
          "minLength": 1
        },
        "allowed_actions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "allowed_modes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "non_exportable": {
          "type": "boolean"
        }
      },
      "required": [
        "binding_id",
        "backend_profile_id",
        "materializer_profile_id"
      ]
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stream_id": {
          "type": "string",
          "minLength": 1
        },
        "last_sequence": {
          "type": "integer",
          "minimum": 0
        },
        "last_event_hash": {
          "type": "string",
          "minLength": 1
        },
        "checkpoint_source_id": {
          "type": "string",
          "minLength": 1
        },
        "payload_hash": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "stream_id",
        "last_sequence",
        "last_event_hash"
      ]
    },
    "charts": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "bridge",
          "secret-core",
          "materialization",
          "provider-plane",
          "audit"
        ]
      },
      "uniqueItems": true,
      "minItems": 1
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "version",
    "context_id",
    "coherence_level",
    "request",
    "secret",
    "resource_secret_binding",
    "policy",
    "provider_facts",
    "binding",
    "audit",
    "charts"
  ]
}

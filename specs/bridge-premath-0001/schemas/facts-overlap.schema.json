{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "facts-overlap.schema.json",
  "title": "FactsOverlap",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "deployment_profile_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_catalog_id": {
      "type": "string",
      "minLength": 1
    },
    "attestation_id": {
      "type": "string",
      "minLength": 1
    },
    "posture_digest": {
      "type": "string",
      "minLength": 1
    },
    "revocation_snapshot_id": {
      "type": "string",
      "minLength": 1
    },
    "issuer_epoch": {
      "oneOf": [
        {
          "type": "integer"
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "mode_epoch": {
      "oneOf": [
        {
          "type": "integer"
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "audit_sink_id": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "deployment_profile_id",
    "provider_catalog_id",
    "attestation_id",
    "posture_digest",
    "revocation_snapshot_id",
    "issuer_epoch",
    "mode_epoch",
    "audit_sink_id"
  ]
}
